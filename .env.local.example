# ClickNComply environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit secrets.

# ---------------------------------------------------------------
# Site
# ---------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=ClickNComply

# ---------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------
# From your Supabase project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_DO_NOT_EXPOSE

# ---------------------------------------------------------------
# Anthropic — Claude Haiku 4.5 for AI generation
# ---------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------
# Stripe
# ---------------------------------------------------------------
# Test keys for dev, live keys for production
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create products in Stripe Dashboard, paste the price IDs here)
STRIPE_PRICE_PRO_MONTHLY=price_...        # £9/mo
STRIPE_PRICE_PRO_ANNUAL=price_...         # £86/yr (saves 20%)

# ---------------------------------------------------------------
# Resend — transactional email
# ---------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@clickncomply.app
RESEND_REPLY_TO=hello@clickncomply.app
